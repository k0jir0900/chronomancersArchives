# Copy this file to .env and fill in the values.
#   cp .env.example .env

# GENERAL
TZ=America/Santiago
# SECRET_KEY is generated automatically on startup (entrypoint.sh) and persisted
# in the app_secrets volume. Set it here only if you want to pin a fixed value.
# SECRET_KEY=

# CERTIFICATE
DOMAIN=localhost
DAYS=826

# DB
# Root password is random per init (MYSQL_RANDOM_ROOT_PASSWORD in docker-compose); the app does not use root.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=chronomancers_archives
DB_USER=chronomancers_user
DB_PASSWORD=change_me_db_password

# Optional: MySQL connection pool size (default 10, max 32)
# DB_POOL_SIZE=10
