# Copy this file to .env and fill in the values.
#   cp .env.example .env

# GENERAL
TZ=America/Santiago
# SECRET_KEY is generated automatically on startup (entrypoint.sh) and persisted
# in the app_secrets volume. Set it here only if you want to pin a fixed value.
# SECRET_KEY=
# Set to true only when serving over HTTPS (cookies sent on secure connections only).
SESSION_COOKIE_SECURE=false
# Set to true only when running behind a trusted reverse proxy (honors X-Forwarded-For/Proto
# so rate limiting and audit logs use the real client IP). Leave false otherwise.
TRUST_PROXY=false
# Gunicorn tuning (single worker; concurrency via threads, see entrypoint.sh).
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120

# CERTIFICATE / TLS
# When ENABLE_SSL=true, the entrypoint generates a self-signed cert for DOMAIN
# (valid DAYS days) and gunicorn serves HTTPS on 5001. Set SESSION_COOKIE_SECURE=true
# together with this.
ENABLE_SSL=false
DOMAIN=localhost
DAYS=826

# DB
# Root password is random per init (MYSQL_RANDOM_ROOT_PASSWORD in docker-compose); the app does not use root.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=chronomancers_archives
DB_USER=chronomancers_user
DB_PASSWORD=change_me_db_password

# Optional: MySQL connection pool size (default 10, max 32)
# DB_POOL_SIZE=10
